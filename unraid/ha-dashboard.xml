<?xml version="1.0"?>
<Container version="2">
  <Name>HA-Dashboard</Name>
  <Repository>ghcr.io/Tjindarr/family-hub-display:latest</Repository>
  <Registry>https://ghcr.io/Tjindarr/family-hub-display</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Tjindarr/family-hub-display/issues</Support>
  <Project>https://github.com/Tjindarr/family-hub-display</Project>
  <Overview>A self-hosted Home Assistant dashboard with chores, sensors, calendar, weather and more. Optimized for kiosk mode on Raspberry Pi or any browser.</Overview>
  <Category>HomeAutomation: Productivity:</Category>
  <WebUI>http://[IP]:[PORT:80]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/Tjindarr/family-hub-display/main/unraid/ha-dashboard.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/Tjindarr/family-hub-display/main/unraid/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>A self-hosted Home Assistant dashboard with chores, sensors, calendar, weather and more. Configuration and data persist in /data.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8087</HostPort>
        <ContainerPort>80</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/ha-dashboard</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Config Name="WebUI Port" Target="80" Default="8087" Mode="tcp" Description="HTTP port for the dashboard" Type="Port" Display="always" Required="true" Mask="false">8087</Config>
  <Config Name="App Data" Target="/data" Default="/mnt/user/appdata/ha-dashboard" Mode="rw" Description="Persistent config, chores, photos, vapid keys" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/ha-dashboard</Config>
</Container>
